{
  "name": "cc-monitor-pet",
  "version": "0.1.0",
  "description": "CC monitor pet — visualizes Claude Code agent activity",
  "main": "src/main.js",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "install-hooks": "node hooks/install.js",
    "mcp": "node mcp/pet-server.js"
  },
  "build": {
    "appId": "com.cc-monitor-pet.app",
    "productName": "CC Monitor Pet",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "hooks/**/*",
      "node_modules/**/*"
    ]
  },
  "keywords": [
    "claude",
    "claude-code",
    "desktop-pet",
    "electron"
  ],
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  }
}
