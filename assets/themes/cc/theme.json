    "juggling":     { "file": "juggling.svg",     "oneShot": false },
    "carrying":     { "file": "carrying.svg",     "oneShot": false },
    "attention":    { "file": "attention.svg",    "oneShot": true  },
    "sweeping":     { "file": "sweeping.svg",     "oneShot": false },
    "notification": { "file": "notification.svg", "oneShot": true  },
    "error":        { "file": "error.svg",        "oneShot": true  },
    "yawning":      { "file": "yawning.svg",      "oneShot": false },
    "dozing":       { "file": "dozing.svg",       "oneShot": false },
    "collapsing":   { "file": "collapsing.svg",   "oneShot": false },
    "sleeping":     { "file": "sleeping.svg",     "oneShot": false },
